generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // <-- Ajout de cette ligne vitale
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  pseudo    String
  xp        Int      @default(0)
  level     Int      @default(1)
  tasks     Task[]   // Relation : un utilisateur possède plusieurs tâches
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id          String   @id @default(uuid())
  title       String
  difficulty  Int      // 1 = Facile, 2 = Moyen, 3 = Difficile
  isCompleted Boolean  @default(false)
  
  // Clé étrangère et relation avec le User
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}