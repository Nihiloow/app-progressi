generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // <-- Ajout de cette ligne vitale
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  pseudo    String
  xp        Int      @default(0)
  level     Int      @default(1)
  tasks     Task[]   
  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// drapeaux de priorité
enum Priority {
  HIGH
  MEDIUM
  LOW
  NONE
}

// charge cognitive
enum TaskType {
  DEEP_WORK       
  SHALLOW_WORK 
  ADMINISTRATIVE
  NONE
}

// modèle Task
model Task {
  id          String   @id @default(uuid())
  title       String
  difficulty  Int      @default(1)
  isCompleted Boolean  @default(false)
  dueDate     DateTime?
  
  priority    Priority @default(NONE)
  taskType    TaskType @default(SHALLOW_WORK)
  
  tags        Tag[]
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// tags
model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String?
  
  // relation inverse vers les tâches
  tasks     Task[]
  
  // un tag appartient à un utilisateur spécifique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // un utilisateur ne peut pas créer deux fois le même nom de tag
  @@unique([name, userId])
}