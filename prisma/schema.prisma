generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

// Permet à l'admin de désactiver un compte sans le supprimer (exigence du CDC)
enum AccountStatus {
  ACTIVE
  DISABLED
}

// Importance de la tâche (drapeaux façon TickTick) : seule source du barème XP
enum Priority {
  HIGH
  MEDIUM
  LOW
  NONE
}

// Nature cognitive de la tâche : axe d'organisation, neutre en XP
enum TaskType {
  DEEP_WORK
  SHALLOW_WORK
  ADMINISTRATIVE
  NONE
}

// Remplace le booléen isCompleted : WONT_DO = "Ne fera pas" (façon TickTick),
// distinct de DONE car abandonner une tâche ne rapporte pas d'XP
enum TaskStatus {
  TODO
  DONE
  WONT_DO
}

// GAIN à la complétion, REFUND au décochage (montant négatif)
enum XpEventType {
  GAIN
  REFUND
}

// Fréquence de l'habitude. Seul DAILY est implémenté en v1 — le CDC ne
// demande que des "jours consécutifs". WEEKLY existe dans l'enum pour ne
// pas fermer la porte au schéma, mais le service rejette tout ce qui n'est
// pas DAILY (YAGNI : pas de logique de calcul de streak hebdo demandée).
enum HabitFrequency {
  DAILY
  WEEKLY
}

// Type de comportement suspect détecté. Un seul type implémenté en v1
// (RAPID_CYCLE) : volontairement restreint à ce qui a un sens de triche
// réel ici — un cycle complet validation→décochage ne rapporte jamais
// plus d'XP net (le refund est exact), répéter ce cycle n'a donc aucun
// intérêt légitime. L'enum laisse la porte ouverte à d'autres types futurs
// sans migration de schéma à chaque ajout.
enum ModerationFlagType {
  RAPID_CYCLE
}

// Phase d'une session Pomodoro : alterne travail et pause, chacune
// skippable. Seule la phase WORK rapporte de l'XP (cf. PomodoroSession).
enum PomodoroPhase {
  WORK
  BREAK
}

// ─── Modèles ─────────────────────────────────────────────────────────────────

model User {
  id              String            @id @default(uuid())
  email           String            @unique
  password        String
  pseudo          String
  role            Role              @default(USER)
  status          AccountStatus     @default(ACTIVE)
  xp              Int               @default(0)
  level           Int               @default(1)
  // Nullable : aucun avatar par défaut, l'initiale du pseudo reste le repli
  // côté front (cf. AvatarRing). Stocke l'URL publique Supabase Storage
  // complète (avec query de cache-busting), pas un chemin relatif — évite
  // de recalculer l'URL publique côté front à chaque affichage.
  avatarUrl       String?
  tasks           Task[]
  tags            Tag[]
  habits          Habit[]
  xpEvents        XpEvent[]
  moderationFlags ModerationFlag[]
  pomodoroSessions PomodoroSession[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model Task {
  id          String     @id @default(uuid())
  title       String
  status      TaskStatus @default(TODO)
  // Figé à la complétion : sert au quota journalier (et non updatedAt,
  // qui bouge à chaque modification et fausserait le comptage)
  completedAt DateTime?
  dueDate     DateTime?
  description String?

  priority Priority @default(NONE)
  taskType TaskType @default(NONE)

  tags             Tag[]
  xpEvents         XpEvent[]
  moderationFlags  ModerationFlag[]
  pomodoroSessions PomodoroSession[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // La liste des tâches filtre par userId et trie par createdAt desc :
  // cet index sert le filtre ET le tri (scan d'index pré-trié, pas de sort).
  @@index([userId, createdAt])
}

model Tag {
  id    String  @id @default(uuid())
  name  String
  color String?

  tasks Task[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Un utilisateur ne peut pas créer deux fois le même nom de tag
  @@unique([name, userId])

  // L'unique ci-dessus a `name` en tête : il ne sert pas un filtre par
  // userId seul (liste des tags). D'où cet index dédié sur la clé étrangère.
  @@index([userId])
}

// Habitude récurrente (quête répétée, distincte de Task = quête unique).
// currentStreak/bestStreak/lastCompletedOn sont un CACHE de lecture,
// recalculé en transaction — même pattern que User.xp/level : la source de
// vérité réelle est HabitCompletion (append-only), jamais ce cache.
model Habit {
  id         String         @id @default(uuid())
  title      String
  frequency  HabitFrequency @default(DAILY)
  priority   Priority       @default(NONE)
  isArchived Boolean        @default(false)

  currentStreak   Int       @default(0)
  bestStreak      Int       @default(0)
  // Jour calendaire de la dernière validation (toujours normalisé à 00:00
  // local au moment de l'écriture), pas un timestamp précis — sert au calcul
  // paresseux de rupture de streak à la lecture.
  lastCompletedOn DateTime?

  completions HabitCompletion[]
  xpEvents    XpEvent[]

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
}

// Une ligne = un jour validé pour une habitude donnée. Append-only, jamais
// modifiée ni supprimée — c'est le journal de vérité du streak, au même
// titre que XpEvent pour l'XP. completedOn est un jour calendaire normalisé
// (00:00 local), pas un timestamp : l'unique ci-dessous empêche physiquement
// deux validations le même jour pour la même habitude.
model HabitCompletion {
  id          String   @id @default(uuid())
  completedOn DateTime

  habitId String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([habitId, completedOn])
  @@index([habitId, completedOn])
}

// Livre de comptes de l'XP : source de vérité unique, append-only.
// Le solde User.xp/level est un cache de lecture maintenu en transaction.
// Sert aussi de log des actions critiques (exigence du CDC) et alimente
// les graphiques d'évolution sur 30 jours.
model XpEvent {
  id     String      @id @default(uuid())
  type   XpEventType
  amount Int // positif pour GAIN, négatif pour REFUND

  // Priorité au moment de la complétion, figée : changer la priorité
  // d'une tâche ou d'une habitude complétée ne réécrit pas l'historique.
  // Pour un Pomodoro sans tâche liée, vaut NONE (valeur neutre déjà
  // utilisée comme défaut sur Task.priority/Habit.priority).
  priority Priority

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // SetNull : supprimer une tâche ne falsifie pas le livre de comptes.
  // Un événement vient d'une tâche, d'une habitude OU d'une session
  // Pomodoro, jamais de deux à la fois — règle disciplinée au niveau
  // du service (pas de CHECK constraint SQL), documentée ici plutôt
  // qu'imposée en base.
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  habitId String?
  habit   Habit?  @relation(fields: [habitId], references: [id], onDelete: SetNull)

  pomodoroSessionId String?
  pomodoroSession   PomodoroSession? @relation(fields: [pomodoroSessionId], references: [id], onDelete: SetNull)

  // Un REFUND pointe le GAIN qu'il annule ; @unique garantit en base
  // qu'un même gain ne peut pas être remboursé deux fois
  revertsEventId String?  @unique
  revertsEvent   XpEvent? @relation("Reversal", fields: [revertsEventId], references: [id])
  revertedBy     XpEvent? @relation("Reversal")

  createdAt DateTime @default(now())

  // Les graphiques agrègent toujours par (userId, createdAt)
  @@index([userId, createdAt])

  // La réouverture d'une tâche (remboursement) cherche le GAIN actif par
  // taskId : sans index, scan séquentiel. La clé étrangère n'est pas
  // indexée d'office par Postgres/Prisma.
  @@index([taskId])

  // Même rationale que taskId, pour les futurs remboursements d'habitudes
  @@index([habitId])

  // Même rationale, pour les sessions Pomodoro
  @@index([pomodoroSessionId])
}

// Journal d'événements suspects, distinct du XpEvent (qui reste un livre
// de comptes financier, pas un journal de modération). Append-only,
// jamais modifié — un flag existe ou n'existe pas, on ne le "résout" pas
// en le supprimant : la trace doit survivre pour l'audit, même si l'admin
// décide de ne rien faire derrière. AUCUNE sanction automatique n'est
// déclenchée par la création d'un flag : c'est une donnée de visibilité
// pour l'admin, qui garde la décision humaine (cohérent avec setStatus/
// resetProgression qui sont des actions admin explicites, jamais auto).
model ModerationFlag {
  id     String             @id @default(uuid())
  type   ModerationFlagType
  // Compte rendu lisible côté admin sans avoir à recalculer le contexte
  // depuis le ledger — ex: "4 cycles validation/décochage en 6 minutes".
  detail String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Nullable : un flag concerne presque toujours une tâche précise, mais
  // SetNull plutôt que Cascade — supprimer la tâche ne doit pas effacer
  // la trace que l'admin a pu consulter avant suppression.
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  // Le dashboard admin liste par défaut les flags les plus récents,
  // et filtre potentiellement par utilisateur.
  @@index([createdAt])
  @@index([userId])
}

// Une ligne = une session Pomodoro TERMINÉE (fin naturelle ou arrêt
// manuel) — le minuteur en cours est un state client volatile, jamais
// persisté tant qu'il tourne (pas de reprise après refresh, choix acté).
// actualWorkSeconds est le temps RÉEL en phase WORK, seul compte pour
// xpFromTime — la phase BREAK ne rapporte jamais d'XP. xpFromTime et
// xpFromTask sont stockés séparément (pas fusionnés) pour permettre
// l'affichage détaillé façon TickTick dans l'historique.
model PomodoroSession {
  id             String  @id @default(uuid())

  workMinutes    Int     // durée PRÉVUE de la phase WORK, personnalisable
  breakMinutes   Int     // durée PRÉVUE de la phase BREAK, personnalisable
  autoChainBreak Boolean @default(false)

  // Temps RÉEL effectué en phase WORK, peut être < workMinutes*60 si la
  // session a été arrêtée avant la fin (XP partiel, cf. règle métier)
  actualWorkSeconds Int

  // Figés à la complétion, jamais recalculés (append-only, même
  // discipline que XpEvent)
  xpFromTime Int @default(0)
  xpFromTask Int @default(0)

  startedAt DateTime
  endedAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tâche active AU MOMENT DE LA FIN de la session, nullable — l'utilisateur
  // peut changer de tâche en cours de séance (une seule active à la fois),
  // seule celle en place à la fin compte pour xpFromTask. SetNull : même
  // politique que XpEvent.taskId, supprimer la tâche ne falsifie pas
  // l'historique Pomodoro.
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  xpEvents XpEvent[]

  createdAt DateTime @default(now())

  // L'historique façon TickTick liste par utilisateur, trié par date
  @@index([userId, createdAt])
}